    {
      "parameters": {
        "jsCode": "const listings = $input.all().map(item => item.json);\n\nif (listings.length === 0) {\n  return [{\n    json: {\n      marketStats: {\n        avgPrice: 0,\n        medianPrice: 0,\n        minPrice: 0,\n        maxPrice: 0,\n        competitorCount: 0\n      },\n      recommendedPrice: 0,\n      monthlyRevenue: 0\n    }\n  }];\n}\n\nconst prices = listings\n  .map(l => parseFloat(l.price))\n  .filter(p => !isNaN(p) && p > 0)\n  .slice(0, 3000); \n\nprices.sort((a, b) => a - b);\n\nconst q1 = prices[Math.floor(prices.length * 0.25)];\nconst q3 = prices[Math.floor(prices.length * 0.75)];\nconst iqr = q3 - q1;\n\nconst lowerBound = q1 - 1.5 * iqr;\nconst upperBound = q3 + 1.5 * iqr;\n\nconst filteredPrices = prices.filter(p => p >= lowerBound && p <= upperBound);\n\nconst avgPrice = filteredPrices.reduce((a, b) => a + b, 0) / filteredPrices.length;\nconst medianPrice = filteredPrices[Math.floor(filteredPrices.length / 2)];\nconst minPrice = Math.min(...filteredPrices);\nconst maxPrice = Math.max(...filteredPrices);\n\nconst recommendedPrice = Math.round(medianPrice);\n\nconst monthlyRevenue = Math.round(recommendedPrice * 30 * 0.7);\n\nreturn [{\n  json: {\n    marketStats: {\n      avgPrice: Math.round(avgPrice),\n      medianPrice: Math.round(medianPrice),\n      minPrice: Math.round(minPrice),\n      maxPrice: Math.round(maxPrice),\n      competitorCount: listings.length\n    },\n    recommendedPrice,\n    monthlyRevenue\n  }\n}];"
      },
      "id": "85330052-6cd1-4817-b6e0-c1035a35a9ae",
      "name": "Calculate Market Stats",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        304
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Here is the market data:\n\nMedian price: {{ $json.marketStats.medianPrice }}\nAverage price: {{ $json.marketStats.avgPrice }}\nMin price: {{ $json.marketStats.minPrice }}\nMax price: {{ $json.marketStats.maxPrice }}\nCompetitors: {{ $json.marketStats.competitorCount }}\n\nHere is the target listing:\n\n{{ JSON.stringify($(\"Set Search Parameters\").first().json) }}\n\nProvide a pricing recommendation.",
        "options": {
          "systemMessage": "You are an Airbnb pricing expert.\n\nUse the provided market data and listing details to estimate an optimal nightly price.\n\nRules:\n- Start from the median market price\n- Apply adjustments based on:\n  • host rating\n  • budget sensitivity\n  • target market\n\nAdjustments:\n- Rating ≥ 4.5 → +10% to +20%\n- Rating 4.0–4.5 → +0% to +10%\n- Rating < 4.0 → -10% to -20%\n\n- Budget sensitivity:\n  • high → -10%\n  • medium → 0%\n  • low → +10%\n\n- Target market:\n  • tourists → +5–15%\n  • business → +0–5%\n  • locals → 0 or slight decrease\n\nConstraints:\n- Final price must stay within ±20% of median price\n\nOutput ONLY a valid JSON (no text outside JSON):\n\n{\n  \"finalPrice\": number,\n  \"adjustments\": \"text\",\n  \"summary\": \"text\"\n}\n\nDo not return anything outside JSON."
        }
      },
