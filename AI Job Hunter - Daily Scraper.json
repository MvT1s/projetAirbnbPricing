    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  const d = item.json;\n\n  if (\n    d.neighbourhood_group &&\n    d.room_type &&\n    d.price\n  ) {\n    output.push({\n      json: {\n        neighbourhood_group: d.neighbourhood_group,\n        room_type: d.room_type,\n        price: parseFloat(d.price)\n      }\n    });\n  }\n\n  if (output.length >= 2000) break;\n}\n\nreturn output;"
      },
